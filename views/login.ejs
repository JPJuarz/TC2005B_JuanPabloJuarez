<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
</head>
<body>
<section class="section">
    <div class="container" style="max-width: 400px;">
        <h1 class="title">Log in</h1>
        <% if (error) { %>
            <div class="notification is-danger"><%= error %></div>
        <% } %>
        <form action="/users/login" method="POST">
            <div class="field">
                <label for="username" class="label">Username</label>
                <div class="control">
                    <input id="username" name="username" class="input" type="text" placeholder="Tu nombre" required>
                </div>
            </div>
            <div class="field">
                <label for="password" class="label">Password</label>
                <div class="control">
                    <input id="password" name="password" class="input" type="password" required>
                </div>
            </div>
            <input class="button is-primary" type="submit" value="Entrar">
        </form>
    </div>
</section>
</body>
</html>